{
  "name": "elmas-dergi",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "ELMAS · Veliköy OSB MTAL aylık okul dergisi — eğitim, üretim ve teknoloji odaklı",
  "scripts": {
    "dev": "astro dev",
    "build": "pnpm process:issues && pnpm tsx scripts/make-default-og.ts && astro build && printf '_worker.js\\n_routes.json\\n' > dist/.assetsignore",
    "preview": "astro preview",
    "astro": "astro",
    "process:issues": "tsx scripts/build-all-issues.ts",
    "process:issue": "tsx scripts/build-issue.ts",
    "new:issue": "tsx scripts/new-issue.ts",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.6",
    "@astrojs/sitemap": "^3.6.0",
    "@tailwindcss/vite": "^4.1.16",
    "astro": "^5.16.4",
    "tailwindcss": "^4.1.16"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.4",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "sharp": "^0.34.4",
    "tsx": "^4.20.4",
    "typescript": "^5.9.3",
    "wrangler": "^4.59.2"
  }
}
