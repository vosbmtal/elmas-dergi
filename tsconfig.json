{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*",
    "worker-configuration.d.ts"
  ],
  "exclude": ["dist", "node_modules", ".wrangler", "tmp", "public/dflip"],
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "types": ["@cloudflare/workers-types"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    }
  }
}
