---
import type { IssueWithStatus } from "~/lib/issues";
import {
  formatTurkishMonthYear,
  issueAssetUrl,
  issueUrl,
} from "~/lib/issues";

interface Props {
  issue: IssueWithStatus;
  variant?: "default" | "compact";
}

const { issue, variant = "default" } = Astro.props;
const { meta, manifest, hasAssets } = issue;

const coverSrc = hasAssets
  ? issueAssetUrl(meta.slug, manifest!.cover.thumb)
  : null;
const monthYear = formatTurkishMonthYear(meta.publishedAt);
const compact = variant === "compact";
---

<a
  href={issueUrl(meta.slug)}
  class="issue-card"
  class:list={[compact && "issue-card--compact"]}
  aria-label={`${meta.title} sayısını oku`}
>
  <div class="issue-card__cover">
    {coverSrc ? (
      <img
        src={coverSrc}
        alt={`${meta.title} kapak görseli`}
        loading="lazy"
        decoding="async"
        width="800"
        height="1132"
      />
    ) : (
      <div class="issue-card__placeholder">
        <span class="text-display">ELMAS</span>
        <span class="text-xs uppercase tracking-[0.24em] mt-2">
          Sayı {meta.issueNumber}
        </span>
      </div>
    )}
  </div>
  <div class="issue-card__body">
    <p class="issue-card__eyebrow">Sayı {meta.issueNumber}</p>
    <h3 class="issue-card__title">{meta.title}</h3>
    <p class="issue-card__date">{monthYear}</p>
    {!compact && meta.summary && (
      <p class="issue-card__summary">{meta.summary}</p>
    )}
    <span class="issue-card__cta">
      Oku
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="w-4 h-4">
        <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </span>
  </div>
</a>

<style>
  .issue-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-radius: 1rem;
    background: white;
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .issue-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-lg);
  }
  .issue-card:focus-visible {
    outline: 3px solid var(--color-gold);
    outline-offset: 3px;
  }
  .issue-card__cover {
    position: relative;
    aspect-ratio: 1 / 1.4142; /* A4 */
    overflow: hidden;
    background: var(--color-green-900);
  }
  .issue-card__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }
  .issue-card:hover .issue-card__cover img {
    transform: scale(1.04);
  }
  .issue-card__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, var(--color-green-900), var(--color-green-950));
    color: var(--color-silver-200);
  }
  .issue-card__placeholder .text-display {
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.02em;
  }
  .issue-card__body {
    padding: 0 1.25rem 1.5rem;
  }
  .issue-card__eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-green-700);
  }
  .issue-card__title {
    font-size: 1.5rem;
    margin-top: 0.35rem;
  }
  .issue-card__date {
    font-size: 0.85rem;
    color: var(--color-ink-2);
    opacity: 0.75;
    margin-top: 0.2rem;
  }
  .issue-card__summary {
    margin-top: 0.75rem;
    font-size: 0.92rem;
    line-height: 1.55;
    color: var(--color-ink-2);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .issue-card__cta {
    margin-top: 1.1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--color-green-800);
  }
  .issue-card--compact .issue-card__cover {
    aspect-ratio: 1 / 1.2;
  }
</style>
