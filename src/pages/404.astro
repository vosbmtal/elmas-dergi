---
import BaseLayout from "~/layouts/BaseLayout.astro";

export const prerender = true;
---

<BaseLayout
  title="Sayfa Bulunamadı · ELMAS Dergisi"
  description="Aradığınız sayfa bulunamadı."
  noIndex
>
  <section class="container-prose py-24 text-center">
    <p class="text-xs uppercase tracking-[0.28em] text-green-700">404</p>
    <h1 class="text-display mt-4 text-5xl font-black sm:text-6xl">
      Sayfa Bulunamadı
    </h1>
    <p class="mt-5 mx-auto max-w-md text-ink-2">
      Aradığınız sayfa burada değil. Belki anasayfaya veya arşive göz atmak
      istersiniz?
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a class="btn-primary" href="/">Anasayfa</a>
      <a class="btn-ghost" href="/arsiv">Arşiv</a>
    </div>
  </section>
</BaseLayout>
