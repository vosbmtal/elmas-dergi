---
import BaseLayout from "~/layouts/BaseLayout.astro";

export const prerender = true;

const description =
  "ELMAS, Çerkezköy'deki Veliköy OSB Mesleki ve Teknik Anadolu Lisesi'nin aylık dergisidir. Dergi ekibini, okulun misyonunu ve iletişim bilgilerini buradan öğrenin.";
---

<BaseLayout
  title="Hakkımızda · ELMAS Dergisi · Veliköy OSB MTAL"
  description={description}
>
  <section class="container-prose py-14 sm:py-20">
    <p class="text-xs uppercase tracking-[0.24em] text-green-700">Hakkımızda</p>
    <h1 class="text-display mt-3 text-4xl font-black sm:text-5xl">
      Veliköy OSB MTAL ve ELMAS Dergisi
    </h1>

    <div class="prose mt-10 max-w-3xl space-y-8 text-ink-2 leading-relaxed">
      <div>
        <h2 class="text-display text-2xl font-bold text-ink">Okulumuz</h2>
        <p class="mt-3 text-pretty">
          Çerkezköy'de yer alan Veliköy OSB Mesleki ve Teknik Anadolu Lisesi,
          2017 yılında temeli atılan ve 2020 yılında eğitim-öğretime başlayan;
          sanayinin ihtiyaç duyduğu nitelikli insan gücünü yetiştirmeyi amaçlayan
          bir meslek lisesidir. Organize Sanayi Bölgesi içinde yer alması sayesinde
          öğrencilerine uygulamalı eğitim imkânı sunan okul; <strong>kimya, makine,
          metal, plastik ve otomasyon</strong> gibi alanlarda eğitim vermektedir.
        </p>
        <p class="mt-4 text-pretty">
          Okulumuz; TÜBİTAK projeleri, TEKNOFEST çalışmaları, Erasmus programları
          ve Goat Robot Takımı gibi faaliyetlerle öğrencilerini proje üretmeye
          teşvik etmekte, aynı zamanda Elmas Programı kapsamında özellikle
          savunma sanayine yönelik farkındalık kazandırmayı hedeflemektedir. Bu
          yönüyle öğrencilerini hem iş hayatına hem de yükseköğretime hazırlayan
          yenilikçi bir eğitim kurumu olarak öne çıkmaktadır.
        </p>
      </div>

      <div>
        <h2 class="text-display text-2xl font-bold text-ink">ELMAS Dergisi</h2>
        <p class="mt-3 text-pretty">
          ELMAS, Veliköy OSB MTAL'in aylık dergisidir. Eğitim, üretim ve
          teknoloji odaklı çalışmalarımızı; öğrencilerimizin başarılarını,
          projelerini ve okul hayatımızdaki gelişmeleri sizlerle paylaşmayı
          amaçlıyoruz. İlk sayımız Nisan 2026'da yayınlanmıştır.
        </p>
        <p class="mt-4">
          <strong class="text-ink">Dergi Ekibi:</strong>
          Mehtap Pülgir · Nagihan Karakaya
        </p>
        <p class="mt-2">
          <strong class="text-ink">Öğrenci Ekibi:</strong>
          Halil İbrahim Öz · Emirhan Akın
        </p>
      </div>

      <div>
        <h2 class="text-display text-2xl font-bold text-ink">Kullanılan Kaynaklar</h2>
        <p class="mt-3 text-pretty">
          Bu site açık kaynak ve özgür yazılım bileşenleri kullanılarak hazırlanmıştır.
          Dergi okuma deneyimi için
          <a
            href="https://js.dearflip.com/"
            target="_blank"
            rel="noopener nofollow"
            class="text-green-800 underline-offset-4 hover:underline"
          >DearFlip jQuery/JS Flipbook</a>
          ücretsiz sürümü kullanılmaktadır
          (<a
            href="https://creativecommons.org/licenses/by-nc-nd/4.0/"
            target="_blank"
            rel="noopener nofollow license"
            class="text-green-800 underline-offset-4 hover:underline"
          >CC BY-NC-ND 4.0</a> lisansı ile, ticari olmayan eğitim amaçlı kullanım).
        </p>
      </div>

      <div>
        <h2 class="text-display text-2xl font-bold text-ink">İletişim</h2>
        <address class="mt-4 not-italic space-y-2">
          <p>Veliköy OSB Mahallesi, 12. Cadde No: 6/1</p>
          <p>Çerkezköy / Tekirdağ</p>
          <p>
            <a href="tel:+905422275962" class="text-green-800 underline-offset-4 hover:underline">
              0 542 227 59 62
            </a>
          </p>
          <p>
            <a
              href="https://velikoyosb.meb.k12.tr"
              target="_blank"
              rel="noopener"
              class="text-green-800 underline-offset-4 hover:underline"
            >
              velikoyosb.meb.k12.tr
            </a>
          </p>
        </address>
      </div>
    </div>
  </section>
</BaseLayout>
